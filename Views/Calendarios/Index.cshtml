@model IEnumerable<Timely.Models.Calendario>

@{
    ViewData["Title"] = "Calendario de Eventos";
}

<h2>Calendario de Eventos</h2>
<button id="btnAgregar" class="btn btn-success">Agregar Evento</button>
<div id="calendar"></div>

<!-- Modal para Agregar Evento -->
<div id="modalAgregar" class="modal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Agregar Evento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label>Id:</label>
                <input type="number" id="id" class="form-control" />
                <label>Título:</label>
                <input type="text" id="titulo" class="form-control">
                <label>Fecha Inicio:</label>
                <input type="datetime-local" id="fechaInicio" class="form-control">
                <label>Fecha Fin:</label>
                <input type="datetime-local" id="fechaFinal" class="form-control">
                <label>Descripción:</label>
                <textarea id="descripcion" class="form-control"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" id="guardarEvento" class="btn btn-primary">Guardar</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>
        </div>
    </div>
</div>

<!-- FullCalendar & Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/locales/es.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        var calendarEl = document.getElementById('calendar');
        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            locale: 'es',
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek,timeGridDay'
            },
            eventDidMount: function (info){
                info.el.classList.add("evento-punto");
            },
            events: '/Calendarios/ObtenerEventos',
            eventClick: function (info) {
            const evento = info.event;

            let detalle = 
             "📌 " + (evento.title || "Sin título") + "\n" +
             "📅 Inicio: " + evento.start.toLocaleString() + "\n" +
             "🕓 Fin: " + (evento.end ? evento.end.toLocaleString() : "No especificado") + "\n" +
              "📝 Descripción: " + (evento.extendedProps.description || "Sin descripción");

             alert(detalle);
             },

            dateClick: function (info) {
                $("#fechaInicio").val(info.dateStr + "T00:00");
                $("#fechaFinal").val(info.dateStr + "T23:59");
                $("#modalAgregar").modal("show");
            }


        });
        calendar.render();

        $("#btnAgregar").click(function () {
            $("#modalAgregar").modal("show");
        });

        $("#guardarEvento").click(function () {
            var evento = {
                Id: $("#id").val(),
                Titulo: $("#titulo").val(),
                FechaInicio: $("#fechaInicio").val(),
                FechaFinal: $("#fechaFinal").val(),
                Descripcion: $("#descripcion").val()
            };

            $.ajax({
                url: "/Calendarios/CrearEvento",
                type: "POST",
                contentType: "application/json",  // Indica que se envían datos en JSON
                processData: false,  // Evita que el jQuery procese los datos automáticamente
                data: JSON.stringify(evento),
                success: function (response) {
                    if (response.success) {
                        calendar.refetchEvents();
                        calendar.render();
                        $("#modalAgregar").modal("hide");
                    }
                   else {
                       alert("Error al guardar: " + response.message);
                   }
                },
                error: function() {
                    alert("Hubo un error al conectar con el servidor.");
                }
            });
        });
    });
</script>

<style>
    .evento-punto {
        background: none !important;
        border: none !important;
        padding: 0 !important;
        overflow: visible !important;
        height: 1em !important;
        width: 1em !important;
        position: relative;
    }

    .evento-punto::before {
            content: "●";
            color: mediumpurple; 
            font-size: 1.2rem;
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            line-height: 1;
    }

</style>