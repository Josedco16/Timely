@model IEnumerable<Timely.Models.Usuarios>

@{
    ViewData["Title"] = "Login";
}

<style>
    body {
        background: linear-gradient(to bottom, #1565C0, #64B5F6);
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .card {
        background: white;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0px 5px 15px rgba(0, 0, 0, 0.2);
        width: 350px;
        text-align: center;
    }

    .form-control {
        border-radius: 10px;
    }

    .btn-primary {
        background-color: #1565C0;
        border: none;
        border-radius: 10px;
        padding: 10px;
        font-size: 18px;
    }

        .btn-primary:hover {
            background-color: #0D47A1;
        }

    .text-link {
        color: #1565C0;
        text-decoration: none;
        font-weight: bold;
    }

        .text-link:hover {
            text-decoration: underline;
        }
</style>

<script>
    var menu = document.getElementById("menu");
    menu.style.display = "none";
</script>

<div class="card">
    <h3 class="mb-3">Iniciar sesión</h3>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @Html.ValidationSummary(false, "", new { @class = "text-danger" })
        </div>
    }

    <form asp-action="Login">
        <div class="form-group">
            <label>Usuario</label>
            <input type="text" name="usuario" class="form-control" required />
        </div>

        <div class="form-group mt-3">
            <label>Contraseña</label>
            <input type="password" name="Contrasena" class="form-control" required />
        </div>

        <div class="text-center mt-4">
            <input type="submit" value="Iniciar sesión" class="btn btn-primary w-100" />
        </div>
    </form>

    <div class="text-center mt-3">
        <a asp-action="Create" class="text-link">Regístrese Aquí</a>
    </div>
</div>
