@model Timely.Models.Nota

@{
    ViewData["Title"] = "Editar Nota";
}

<link rel="stylesheet" href="~/css/style.css">

<div class="create-container">
    <div class="form-card">
        <h2>Editar nota</h2>

        <form asp-action="Edit" method="post">
            <div class="form-group">
                <label asp-for="Id" class="control-label"></label>
                <input asp-for="Id" class="form-control" readonly />
                <span asp-validation-for="Id" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Titulo" class="control-label">Título</label>
                <input asp-for="Titulo" class="form-control" placeholder="Escribe un título" required />
            </div>

            <div class="form-group">
                <label asp-for="Contenido" class="control-label">Contenido</label>
                <textarea asp-for="Contenido" class="form-control" rows="4" placeholder="Escribe tu nota aquí"></textarea>
            </div>

            <div class="form-group">
                <label asp-for="Carpeta" class="control-label">Carpeta</label>
                <input asp-for="Carpeta" class="form-control" placeholder="Nombre de la carpeta" required />
            </div>

            <button type="submit" class="btn btn-primary">Guardar Cambios</button>
        </form>
    </div>
    <a asp-action="MisNotas" class="back-link">← Volver a la lista</a>
</div>



