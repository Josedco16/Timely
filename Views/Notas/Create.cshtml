@model Timely.Models.Nota

@{
    ViewData["Title"] = "Crear Nota";
}

<link rel="stylesheet" href="~/css/style.css">

<div class="create-container">
    <div class="form-card">
        <h2>Crear nueva nota</h2>

        <form asp-action="Create" method="post">
            <div class="form-group">
                <label asp-for="Id" class="control-label"></label>
                <input asp-for="Id" class="form-control" />
                <span asp-validation-for="Id" class="text-danger"></span>
            </div>
            <label for="titulo">Título</label>
            <input type="text" name="Titulo" id="titulo" placeholder="Escribe un título" required>

            <label for="contenido">Contenido</label>
            <textarea name="Contenido" id="contenido" rows="4" placeholder="Escribe tu nota aquí"></textarea>

            <label for="carpeta">Carpeta</label>
            <input type="text" name="Carpeta" id="carpeta" placeholder="Nombre de la carpeta" required>

            <button type="submit">Guardar Nota</button>
        </form>
    </div>

    <a asp-action="MisNotas" class="back-link">← Volver a la lista</a>
</div>

