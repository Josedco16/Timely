
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Timely</title>
    <link rel="stylesheet" href="/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/css/site.css" asp-append-version="true" />

</head>
<body>
    <div id="top" >
        <div id="slogan" ><h1>Timely</h1></div>
        <img src="/img/bgimportante.jpg" alt="Imagen de cabecera" class="img-fluid" onerror="this.style.display='none'">
    </div>
    <header>
        <nav id="menu" class="navbar navbar-expand-lg navbar-black border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" href="/Usuarios/Login">Timely</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="btn btn-outline-info mx-1" href="/Usuarios/Login">Hogar</a></li>
                        <li class="nav-item"><a class="btn btn-outline-info mx-1" href="/Proyectos/Tablero">Mis Proyectos</a></li>
                        <li class="nav-item"><a class="btn btn-outline-info mx-1" href="/Notas/MisNotas">Notas</a></li>
                        <li class="nav-item"><a class="btn btn-outline-info mx-1" href="/Calendarios/Index">Calendarios</a></li>
                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item"><a class="btn btn-outline-info mx-1" href="/Usuarios/Lista">Lista de Usuarios</a></li>
                        }
                        <li class="nav-item"><a class="btn btn-outline-info mx-1" href="/Usuarios/MiPerfil">Perfil</a></li>
                        <li class="nav-item"><a class="btn btn-outline-info mx-1" href="/Usuarios/Index">Cerrar sesión</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
   
    <script src="/lib/jquery/dist/jquery.min.js"></script>
    <script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
